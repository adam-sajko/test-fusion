{
  "name": "@ex-jest-mono/app",
  "version": "0.0.0",
  "private": true,
  "description": "Webpack + React app (Jest example)",
  "scripts": {
    "dev": "webpack serve --mode development",
    "start": "http-server ./dist -a 127.0.0.1 -p 3000 --cors -s",
    "build": "NODE_ENV=production USE_COVERAGE=1 webpack --mode production",
    "test": "jest --coverage --json --outputFile=./test-results.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache tsconfig.tsbuildinfo coverage test-results.json test-report"
  },
  "dependencies": {
    "@ex-jest-mono/ui": "workspace:*",
    "react": "19.0.4",
    "react-dom": "19.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.25.9",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^24.5.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "babel-jest": "^29.0.0",
    "babel-loader": "^9.1.3",
    "babel-plugin-istanbul": "^7.0.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "http-server": "^14.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporter": "^4.3.0",
    "style-loader": "^4.0.0",
    "typescript": "~5.9.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
