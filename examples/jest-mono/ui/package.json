{
  "name": "@ex-jest-mono/ui",
  "version": "0.0.0",
  "private": true,
  "description": "UI component library (Jest example)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "jest --coverage --json --outputFile=./test-results.json",
    "test:watch": "jest --watch --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache tsconfig.tsbuildinfo test-report test-results.json coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.25.9",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@tools/tsconfig": "workspace:*",
    "@types/jest": "^29.0.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "babel-jest": "^29.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporter": "^4.3.0",
    "react": "19.0.4",
    "react-dom": "19.0.4",
    "typescript": "~5.9.2"
  }
}
