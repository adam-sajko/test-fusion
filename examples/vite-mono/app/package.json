{
  "name": "@ex-vite-mono/app",
  "version": "0.0.0",
  "private": true,
  "description": "Vite + React app (Vite example)",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "start": "http-server ./dist -a 127.0.0.1 -p 3001 --cors -s",
    "build": "NODE_ENV=production USE_COVERAGE=1 vite build",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache tsconfig.tsbuildinfo test-report test-results.json coverage .vite"
  },
  "dependencies": {
    "@ex-vite-mono/ui": "workspace:*",
    "react": "19.0.4",
    "react-dom": "19.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/babel__core": "^7",
    "@types/node": "^24.5.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.0",
    "babel-plugin-istanbul": "^7.0.1",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
