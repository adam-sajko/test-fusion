{
  "name": "@sandbox/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Simple UI component library for sandbox",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache tsconfig.tsbuildinfo test-report test-results.json coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@tools/tsconfig": "workspace:*",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.0.0",
    "react": "19.0.4",
    "react-dom": "19.0.4",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  }
}
